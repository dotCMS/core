{
  "servers": {
    "nx-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "nx-mcp@latest"]
    },
    "primeng": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@primeng/mcp"]
    },
    "angular-cli": {
      "type": "stdio",
      "command": "npx",
      "args": ["@angular/cli", "mcp"],
      "env": {}
    }
  }
}
