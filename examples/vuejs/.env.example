# dotCMS instance URL (no trailing slash needed)
VITE_DOTCMS_HOST=http://localhost:8080
# Read-only API token (System > Users > API Access Key)
VITE_DOTCMS_AUTH_TOKEN=YOUR_API_TOKEN
# Site identifier (Site Browser > Site settings)
VITE_DOTCMS_SITE_ID=59bb8831-6706-4589-9ca0-ff74016e02b2
# Renderer mode: 'production' | 'development'
VITE_DOTCMS_MODE=production
