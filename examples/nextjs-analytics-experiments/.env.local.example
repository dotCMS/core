# dotCMS origin (NOT a CDN / Front Door URL)
NEXT_PUBLIC_DOTCMS_HOST=http://localhost:8080

# API token from dotCMS (Admin → API Tokens)
NEXT_PUBLIC_DOTCMS_AUTH_TOKEN=

# Site identifier (Admin → Sites)
NEXT_PUBLIC_DOTCMS_SITE_ID=demo.dotcms.com

# jsKey from the Analytics/Experiments app (NOT the m2m key)
# Local stack: http://localhost:8088/c/customer1/cluster1/keys
NEXT_PUBLIC_DOTCMS_ANALYTICS_KEY=testsecret

# UVE mode: production | edit
NEXT_PUBLIC_DOTCMS_MODE=production

# Enable verbose SDK logging (analytics + experiments)
NEXT_PUBLIC_DOTCMS_DEBUG=true

# Allow self-signed certs in local dev
NODE_TLS_REJECT_UNAUTHORIZED=0
