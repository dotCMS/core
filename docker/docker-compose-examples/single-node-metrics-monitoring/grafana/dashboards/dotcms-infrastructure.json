{
  "id": 6,
  "title": "dotCMS System Infrastructure",
  "tags": ["dotcms", "infrastructure", "system"],
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "panels": [
    {
      "id": 1,
      "title": "System Resources Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Disk Usage %",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 1},
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          },
          "color": {"mode": "thresholds"},
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "expr": "((disk_total_bytes - disk_free_bytes) / disk_total_bytes) * 100",
          "legendFormat": "Used %",
          "refId": "A"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
    },
    {
      "id": 3,
      "title": "Free Disk Space",
      "type": "stat",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 1},
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 1000000000},
              {"color": "green", "value": 5000000000}
            ]
          },
          "color": {"mode": "thresholds"},
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "disk_free_bytes",
          "legendFormat": "Free Space",
          "refId": "A"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
    },
    {
      "id": 4,
      "title": "Total Disk Space",
      "type": "stat",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 1},
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null}
            ]
          },
          "color": {"mode": "thresholds"},
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "disk_total_bytes",
          "legendFormat": "Total Space",
          "refId": "A"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
    },
    {
      "id": 5,
      "title": "Disk Space Trends",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisLabel": "",
            "axisColorMode": "text",
            "scaleDistribution": {"type": "linear"},
            "axisCenteredZero": false,
            "hideFrom": {"legend": false, "tooltip": false, "vis": false},
            "thresholdsStyle": {"mode": "off"}
          },
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 80}
            ]
          },
          "unit": "bytes"
        }
      },
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "targets": [
        {
          "expr": "disk_free_bytes",
          "legendFormat": "Free Space",
          "refId": "A"
        },
        {
          "expr": "disk_total_bytes - disk_free_bytes",
          "legendFormat": "Used Space",
          "refId": "B"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
    },
    {
      "id": 6,
      "title": "System Load Average",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 9},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisLabel": "",
            "axisColorMode": "text",
            "scaleDistribution": {"type": "linear"},
            "axisCenteredZero": false,
            "hideFrom": {"legend": false, "tooltip": false, "vis": false},
            "thresholdsStyle": {"mode": "off"}
          },
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 2}
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "targets": [
        {
          "expr": "system_load_average_1m",
          "legendFormat": "1m avg",
          "refId": "A"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
    },
    {
      "id": 7,
      "title": "File Descriptors",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 17},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisLabel": "",
            "axisColorMode": "text",
            "scaleDistribution": {"type": "linear"},
            "axisCenteredZero": false,
            "hideFrom": {"legend": false, "tooltip": false, "vis": false},
            "thresholdsStyle": {"mode": "off"}
          },
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 500},
              {"color": "red", "value": 800}
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "targets": [
        {
          "expr": "process_open_fds",
          "legendFormat": "Open FDs",
          "refId": "A"
        },
        {
          "expr": "process_max_fds",
          "legendFormat": "Max FDs",
          "refId": "B"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
    },
    {
      "id": 8,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 17},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisLabel": "",
            "axisColorMode": "text",
            "scaleDistribution": {"type": "linear"},
            "axisCenteredZero": false,
            "hideFrom": {"legend": false, "tooltip": false, "vis": false},
            "thresholdsStyle": {"mode": "off"}
          },
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "targets": [
        {
          "expr": "system_cpu_usage * 100",
          "legendFormat": "System CPU",
          "refId": "A"
        },
        {
          "expr": "process_cpu_usage * 100",
          "legendFormat": "Process CPU",
          "refId": "B"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
    },
    {
      "id": 9,
      "title": "Environment Information",
      "type": "table",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 25},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          },
          "color": {"mode": "thresholds"},
          "unit": "string"
        }
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {"show": false, "reducer": ["sum"], "countRows": false, "fields": ""}
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "application": "Application",
              "customer": "Customer",
              "environment": "Environment",
              "Value": "Value"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "group by (application, customer, environment)(up{application!=\"\"})",
          "format": "table",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "style": "dark",
  "weekStart": "",
  "version": 1
}