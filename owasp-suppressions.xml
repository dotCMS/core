<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        =====================================================================
        Elasticsearch client JARs — server-side CVEs (false positives)
        =====================================================================
        dotCMS uses elasticsearch-rest-high-level-client as a CLIENT ONLY.
        All CVEs below are vulnerabilities in the Elasticsearch SERVER PROCESS
        (node memory management, ingest pipelines, audit logging, PKI realm,
        etc.) and are not present in, or exploitable via, the client JARs
        shipped with dotCMS.

        Customers running their own Elasticsearch cluster should upgrade it
        to 7.17.25+ independently of the dotCMS application.
    -->

    <!-- CVE-2021-22134: DLS/FLS doc-existence leak — server feature, requires Security subscription -->
    <suppress>
        <notes>Server-side DLS/FLS vulnerability. dotCMS ships only the REST client JAR, not the server process.</notes>
        <packageUrl regex="true">^pkg:maven/org\.elasticsearch.*@.*$</packageUrl>
        <cve>CVE-2021-22134</cve>
    </suppress>

    <!-- CVE-2021-22144: Grok parser DoS — server-side query engine -->
    <suppress>
        <notes>Server-side Grok parser vulnerability. Not present in client JARs.</notes>
        <packageUrl regex="true">^pkg:maven/org\.elasticsearch.*@.*$</packageUrl>
        <cve>CVE-2021-22144</cve>
    </suppress>

    <!-- CVE-2021-22145: Memory disclosure in server error paths -->
    <suppress>
        <notes>Server-side memory disclosure. Not present in client JARs.</notes>
        <packageUrl regex="true">^pkg:maven/org\.elasticsearch.*@.*$</packageUrl>
        <cve>CVE-2021-22145</cve>
    </suppress>

