    <!--
        =====================================================================
        dot.struts-1.2.10_1.jar — Struts 2 false positives + non-applicable XStream CVEs
        =====================================================================
        dot.struts is a dotCMS-repackaged Struts 1.x library. Three of the
        five flagged CVEs are Struts 2 vulnerabilities; Dependency Check
        misattributes them due to JAR name pattern matching. Struts 1.x uses
        a fundamentally different architecture with no OGNL parameter handling.

        The two XStream CVEs relate to a bundled XStream dependency.
        dotCMS uses Struts only for legacy JSP/Tiles rendering — XStream
        deserialization is not used in this code path. CVE-2020-26259
        additionally requires Java < 15; dotCMS runs Java 11+/17+.
    -->

    <!-- CVE-2012-0391: Struts 2 OGNL RCE — Struts 1.x has no OGNL parameter handling -->
    <suppress>
        <notes>Struts 2 OGNL RCE misattributed to Struts 1.x JAR. Struts 1.x does not use OGNL for parameter handling.</notes>
        <packageUrl regex="true">^pkg:maven/com\.dotcms\.lib/dot\.struts@.*$</packageUrl>
        <cve>CVE-2012-0391</cve>
    </suppress>

    <!-- CVE-2023-34396: Struts 2 multipart DoS — not applicable to Struts 1.x -->
    <suppress>
        <notes>Struts 2 multipart DoS misattributed to Struts 1.x JAR.</notes>
        <packageUrl regex="true">^pkg:maven/com\.dotcms\.lib/dot\.struts@.*$</packageUrl>
        <cve>CVE-2023-34396</cve>
    </suppress>

    <!-- CVE-2023-34149: Struts 2 DoS — not applicable to Struts 1.x -->
    <suppress>
        <notes>Struts 2 DoS misattributed to Struts 1.x JAR.</notes>
        <packageUrl regex="true">^pkg:maven/com\.dotcms\.lib/dot\.struts@.*$</packageUrl>
        <cve>CVE-2023-34149</cve>
    </suppress>

    <!-- CVE-2020-26258: XStream SSRF — XStream deserialization not used in dotCMS Struts integration -->
    <suppress>
        <notes>XStream SSRF. dotCMS uses Struts 1.x for JSP/Tiles rendering only, not XStream deserialization. Not exploitable.</notes>
        <packageUrl regex="true">^pkg:maven/com\.dotcms\.lib/dot\.struts@.*$</packageUrl>
        <cve>CVE-2020-26258</cve>
    </suppress>

    <!-- CVE-2020-26259: XStream arbitrary file deletion — requires Java < 15 and JAX-WS; dotCMS runs Java 11+/17+ -->
    <suppress>
        <notes>XStream file deletion. Requires Java &lt; 15 (dotCMS runs Java 11+/17+) and JAX-WS runtime. XStream deserialization not used in dotCMS Struts path. Not exploitable.</notes>
        <packageUrl regex="true">^pkg:maven/com\.dotcms\.lib/dot\.struts@.*$</packageUrl>
        <cve>CVE-2020-26259</cve>
    </suppress>

</suppressions>
