                "libs/portlets/dot-content-drive/portlet/**/*",
                "libs/portlets/dot-content-drive/ui/**/*",
                "libs/portlets/dot-es-search/**/*",
                "libs/portlets/dot-experiments/data-access/**/*",
                "libs/portlets/dot-experiments/portlet/**/*",
                "libs/portlets/dot-locales/data-access/**/*",
                "libs/portlets/dot-locales/portlet/**/*",
                "libs/portlets/dot-plugins/**/*",
                "libs/portlets/dot-query-tool/**/*",
                "libs/portlets/dot-tags/**/*",
                "libs/portlets/dot-usage/**/*",
                "libs/portlets/dot-velocity-playground/**/*",
                "libs/portlets/edit-ema/portlet/**/*",
                "libs/portlets/edit-ema/ui/**/*",
                "libs/sdk/ai/**/*",
                "libs/sdk/analytics/**/*",
                "libs/sdk/angular/**/*",
                "libs/sdk/client/**/*",
                "libs/sdk/create-app/**/*",
