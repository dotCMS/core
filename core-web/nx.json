    "defaultBase": "main",
    "ignorePatterns": [
        "**/node_modules",
        "**/*vite.config*.timestamp*",
        "**/*vitest.config*.timestamp*"
    ],
    "release": {
        "version": {
            "preVersionCommand": "pnpm nx run-many -t build"
        }
    },
    "serve": {
        "dependsOn": []
    },
    "analytics": true
}
