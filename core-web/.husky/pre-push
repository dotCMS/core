#!/bin/sh
# Fallback dispatcher — only used if core.hooksPath points here
# (e.g. after running yarn install on an old husky branch in another worktree).
# Normally hooks run from .git/hooks/ via prepare.js.

root="$(git rev-parse --show-toplevel)"

if [ -f "$root/lefthook.yml" ]; then
    # New branch: dispatch to lefthook (requires mise for toolchain)
    if ! command -v lefthook >/dev/null 2>&1 && ! mise which lefthook >/dev/null 2>&1; then
        echo "ERROR: lefthook not found. Run: mise install"
        echo "Skip this hook with: LEFTHOOK=0 git push"
        exit 1
    fi
    if command -v lefthook >/dev/null 2>&1; then
        exec lefthook run pre-push --no-auto-install "$@"
    else
        exec mise exec -- lefthook run pre-push --no-auto-install "$@"
    fi
fi