{
    "name": "agentic-tools",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/agentic-tools/src",
    "projectType": "library",
    "tags": ["scope:agentic"],
    "targets": {
        "build": {
            "executor": "@nx/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/libs/agentic-tools",
                "tsConfig": "libs/agentic-tools/tsconfig.lib.json",
                "packageJson": "libs/agentic-tools/package.json",
                "main": "libs/agentic-tools/src/index.ts",
                "assets": ["libs/agentic-tools/*.md"]
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": ["libs/agentic-tools/**/*.ts"]
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "libs/agentic-tools/jest.config.ts",
                "passWithNoTests": true
            }
        }
    }
}
