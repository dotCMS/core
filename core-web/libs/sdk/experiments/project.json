{
    "name": "sdk-experiments",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/sdk/experiments/src",
    "projectType": "library",
    "tags": [],
    "targets": {
        "build": {
            "cache": true,
            "dependsOn": ["^build"],
            "inputs": [
                "production",
                "^production",
                {
                    "externalDependencies": ["rollup"]
                }
            ]
        },
        "build:iife": {
            "dependsOn": ["^build"],
            "outputs": ["{workspaceRoot}/dist/libs/sdk/experiments/iife"],
            "options": {
                "outDir": "../../../dist/libs/sdk/experiments/iife"
            }
        },
        "publish": {
            "command": "node tools/scripts/publish.mjs sdk-experiments {args.ver} {args.tag}",
            "outputPath": "dist/libs/sdk/experiments",
            "dependsOn": ["build", "test"]
        },
        "nx-release-publish": {
            "options": {
                "packageRoot": "dist/libs/sdk/experiments"
            }
        },
        "test": {
            "options": {
                "passWithNoTests": true
            },
            "configurations": {
                "ci": {
                    "ci": true,
                    "coverage": true
                }
            }
        }
    }
}
