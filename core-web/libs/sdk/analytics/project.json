{
    "name": "sdk-analytics",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/sdk/analytics/src",
    "projectType": "library",
    "tags": ["type:lib", "scope:sdk", "feature:analytics"],
    "targets": {
        "test": {
            "options": {
                "passWithNoTests": true
            },
            "configurations": {
                "ci": {
                    "ci": true,
                    "coverage": true
                }
            }
        },
        "build:standalone": {
            "dependsOn": ["^build"],
            "outputs": ["{workspaceRoot}/dist/libs/sdk/analytics-standalone"],
            "options": {
                "config": "./vite.standalone.config.mts",
                "outDir": "../../../dist/libs/sdk/analytics-standalone"
            }
        }
    }
}
