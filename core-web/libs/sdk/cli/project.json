{
    "name": "sdk-cli",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/sdk/cli/src",
    "projectType": "library",
    "tags": [],
    "targets": {
        "build": {
            "executor": "@nx/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/libs/sdk/cli",
                "main": "libs/sdk/cli/src/index.ts",
                "tsConfig": "libs/sdk/cli/tsconfig.lib.json",
                "assets": ["libs/sdk/cli/*.md"]
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "libs/sdk/cli/jest.config.ts"
            }
        }
    }
}
