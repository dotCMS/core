{
    "name": "sdk-uve",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/sdk/uve/src",
    "projectType": "library",
    "tags": [],
    "targets": {
        "test": {
            "options": {
                "passWithNoTests": true,
                "testEnvironment": "jsdom"
            },
            "configurations": {
                "ci": {
                    "ci": true,
                    "coverage": true
                }
            }
        },
        "lint": {
            "options": {
                "args": ["**/*.ts"]
            }
        },
        "build": {
            "cache": true,
            "dependsOn": ["^build"],
            "inputs": [
                "production",
                "^production",
                {
                    "externalDependencies": ["rollup"]
                }
            ]
        },
        "build:js": {
            "executor": "@nx/esbuild:esbuild",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "../dotCMS/src/main/webapp/ext/uve",
                "outputFileName": "dot-uve",
                "format": ["esm"],
                "tsConfig": "libs/sdk/uve/tsconfig.lib.json",
                "project": "libs/sdk/uve/package.json",
                "entryFile": "libs/sdk/uve/src/script/sdk-editor.ts",
                "external": ["react/jsx-runtime"],
                "compiler": "tsc",
                "extractCss": false,
                "minify": true,
                "declaration": false,
                "generatePackageJson": false,
                "esbuildOptions": {
                    "banner": {
                        "js": "(function(){"
                    },
                    "footer": {
                        "js": "})();"
                    }
                }
            }
        }
    }
}
