{
    "name": "sdk-ai",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/sdk/ai/src",
    "projectType": "library",
    "tags": ["scope:ai"],
    "targets": {
        "generate-spec": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx tsx scripts/generate-spec.ts",
                "cwd": "libs/sdk/ai"
            }
        },
        "build": {
            "dependsOn": ["generate-spec"],
            "cache": true,
            "inputs": [
                "production",
                "^production",
                {
                    "externalDependencies": ["rollup"]
                }
            ]
        },
        "publish": {
            "executor": "nx:run-commands",
            "dependsOn": ["build"],
            "options": {
                "command": "node tools/scripts/publish.mjs sdk-ai {args.ver} {args.tag}"
            }
        },
        "nx-release-publish": {
            "options": {
                "packageRoot": "dist/libs/sdk/ai"
            }
        },
        "lint": {
            "options": {
                "args": ["src/**/*.ts", "scripts/**/*.ts"]
            }
        },
        "test": {
            "dependsOn": ["generate-spec"],
            "options": {
                "passWithNoTests": true
            },
            "configurations": {
                "ci": {
                    "ci": true,
                    "coverage": true
                }
            }
        }
    }
}
