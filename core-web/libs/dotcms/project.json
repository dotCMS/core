{
    "name": "dotcms",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/dotcms/src",
    "projectType": "library",
    "tags": ["skip:test", "skip:lint", "skip:build"],
    "targets": {
        "build": {
            "executor": "@nx/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/libs/dotcms",
                "main": "libs/dotcms/src/index.ts",
                "tsConfig": "libs/dotcms/tsconfig.lib.json",
                "assets": ["libs/dotcms/*.md"]
            }
        },
        "publish": {
            "executor": "nx:run-commands",
            "dependsOn": [
                {
                    "projects": "self",
                    "target": "build"
                }
            ],
            "options": {
                "command": "node tools/scripts/publish.mjs dotcms {args.ver} {args.tag}"
            }
        },
        "test": {
            "outputs": [
                "{workspaceRoot}/coverage/libs/dotcms",
                "{workspaceRoot}/target/core-web-reports"
            ],
            "options": {
                "passWithNoTests": true
            },
            "configurations": {
                "ci": {
                    "ci": true,
                    "coverage": true
                }
            }
        }
    }
}
