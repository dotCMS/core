{
    "name": "dotcms-block-editor",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "sourceRoot": "apps/dotcms-block-editor/src",
    "prefix": "dotcms",
    "tags": ["skip:test", "skip:lint"],
    "targets": {
        "build": {
            "executor": "@angular/build:application",
            "outputs": ["{options.outputPath.base}"],
            "defaultConfiguration": "production",
            "options": {
                "baseHref": "./",
                "outputPath": {
                    "base": "dist/apps/dotcms-block-editor",
                    "browser": ""
                },
                "index": "apps/dotcms-block-editor/src/index.html",
                "browser": "apps/dotcms-block-editor/src/main.ts",
                "polyfills": ["apps/dotcms-block-editor/src/polyfills.ts"],
                "tsConfig": "apps/dotcms-block-editor/tsconfig.app.json",
                "inlineStyleLanguage": "css",
                "assets": [
                    "apps/dotcms-block-editor/src/favicon.ico",
                    "apps/dotcms-block-editor/src/assets"
                ],
                "scripts": [
                    {
                        "bundleName": "generator-runtime",
                        "input": "node_modules/regenerator-runtime/runtime.js"
                    }
                ],
                "styles": [
                    "node_modules/primeicons/primeicons.css",
                    "libs/dotcms-scss/angular/styles.scss",
                    "apps/dotcms-block-editor/src/styles.css"
                ],
                "stylePreprocessorOptions": {
                    "includePaths": ["libs/dotcms-scss/angular"]
                },
                "allowedCommonJsDependencies": ["lodash.isequal", "date-fns"],
                "extractLicenses": false,
                "sourceMap": true,
                "optimization": false,
                "namedChunks": true
            },
            "configurations": {
                "development": {
                    "optimization": false,
                    "sourceMap": true,
                    "namedChunks": true,
                    "extractLicenses": false
                },
                "localhost": {
                    "sourceMap": true,
                    "optimization": false
                },
                "tomcat": {
                    "outputPath": {
                        "base": "../../tomcat9/webapps/ROOT/dotcms-block-editor",
                        "browser": ""
                    },
                    "sourceMap": true,
                    "optimization": false
                },
                "production": {
                    "fileReplacements": [
                        {
                            "replace": "apps/dotcms-block-editor/src/environments/environment.ts",
                            "with": "apps/dotcms-block-editor/src/environments/environment.prod.ts"
                        }
                    ],
                    "optimization": true,
                    "outputHashing": "none",
                    "sourceMap": false,
                    "namedChunks": false,
                    "extractLicenses": false,
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "3.5mb",
                            "maximumError": "4mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "200kb",
                            "maximumError": "250kb"
                        }
                    ]
                }
            }
        },
        "serve": {
            "executor": "@angular/build:dev-server",
            "continuous": true,
            "options": {
                "buildTarget": "dotcms-block-editor:build:development"
            },
            "configurations": {
                "production": {
                    "buildTarget": "dotcms-block-editor:build:production"
                },
                "development": {
                    "buildTarget": "dotcms-block-editor:build:development"
                }
            }
        },
        "extract-i18n": {
            "executor": "@angular/build:extract-i18n",
            "options": {
                "buildTarget": "dotcms-block-editor:build"
            }
        },
        "test": {
            "executor": "@angular/build:karma",
            "options": {
                "main": "apps/dotcms-block-editor/src/test.ts",
                "tsConfig": "apps/dotcms-block-editor/tsconfig.spec.json",
                "karmaConfig": "apps/dotcms-block-editor/karma.conf.js",
                "polyfills": ["apps/dotcms-block-editor/src/polyfills.ts"],
                "styles": [],
                "scripts": [],
                "assets": []
            }
        }
    }
}
