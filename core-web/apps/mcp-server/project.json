{
    "name": "mcp-server",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/mcp-server/src",
    "projectType": "application",
    "tags": ["skip:build"],
    "targets": {
        "generate-spec": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx tsx scripts/generate-spec.ts",
                "cwd": "apps/mcp-server"
            }
        },
        "build": {
            "executor": "nx:run-commands",
            "outputs": ["{workspaceRoot}/dist/apps/mcp-server"],
            "options": {
                "commands": [
                    "npx tsx scripts/generate-spec.ts {args.specUrl}",
                    "npx xmcp build",
                    "cp package.json ../../dist/apps/mcp-server/",
                    "cp README.md ../../dist/apps/mcp-server/"
                ],
                "cwd": "apps/mcp-server",
                "parallel": false,
                "forwardAllArgs": false
            }
        },
        "serve": {
            "executor": "nx:run-commands",
            "dependsOn": ["generate-spec"],
            "options": {
                "command": "npx xmcp dev",
                "cwd": "apps/mcp-server"
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "dependsOn": ["generate-spec"],
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "apps/mcp-server/jest.config.ts",
                "passWithNoTests": true
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "options": {
                "lintFilePatterns": [
                    "apps/mcp-server/src/**/*.ts",
                    "apps/mcp-server/scripts/**/*.ts"
                ]
            }
        }
    }
}
